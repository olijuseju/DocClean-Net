MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env

# ── PyTorch checkpoints (distributed via GitHub Releases instead) ─────────────
checkpoints/*.pt
checkpoints/*.pth
# Keep the directory itself tracked
!checkpoints/.gitkeep

# ── Generated dataset (too large for git, regenerate with generate_dataset.py) ─
data/synthetic/
# Keep directory skeleton
!data/synthetic/.gitkeep

# ── Real test scans (personal images, not redistributable) ───────────────────
data/real_test/
!data/real_test/.gitkeep

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Coverage / test artifacts ─────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/

# ── Misc output files created during development ──────────────────────────────
*.png.bak
debug_*.png
output_*.png
metrics.csv
plots/
